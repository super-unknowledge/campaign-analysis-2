# Postgres credentials — used by the db service and to build DATABASE_URL below
POSTGRES_USER=analyticsuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=analyticsdb

# Full connection string used by init_db.py (ingest) and api/main.py
# Host is "db" — the Docker Compose service name, not localhost
DATABASE_URL=postgresql://analyticsuser:changeme@db:5432/analyticsdb
